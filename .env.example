# =============================================
# FORMBRICKS — Estacionkusmedios
# Copia este archivo a .env y llena los valores
# NUNCA subas .env al repositorio
# =============================================

WEBAPP_URL=https://formbricks-kusmedios.fly.dev
NEXTAUTH_URL=https://formbricks-kusmedios.fly.dev
NEXTAUTH_SECRET=genera_con_openssl_rand_hex_32
ENCRYPTION_KEY=genera_con_openssl_rand_hex_32
CRON_SECRET=genera_con_openssl_rand_hex_32
POSTGRES_PASSWORD=genera_con_openssl_rand_hex_20

# DATABASE_URL se genera automaticamente al hacer fly postgres attach
# DATABASE_URL=postgresql://postgres:PASSWORD@formbricks-kusmedios-db.flycast:5432/formbricks?schema=public

EMAIL_VERIFICATION_DISABLED=1
PASSWORD_RESET_DISABLED=1

# SMTP (opcional)
# MAIL_FROM=noreply@estacionkusmedios.org
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_SECURE_ENABLED=1
# SMTP_USER=tu_correo@gmail.com
# SMTP_PASSWORD=tu_app_password

# OAuth Google (opcional)
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=
